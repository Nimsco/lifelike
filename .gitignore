# ====================================================================
# OS & System Files (Prevents OS-specific noise in git history)
# ====================================================================
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ====================================================================
# IDE / Editor Files (Keeps personal workspace configs local)
# ====================================================================
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ====================================================================
# Node.js Backend & Shared Dependencies
# ====================================================================
node_modules/
backend/node_modules/
frontend/node_modules/

# Logs & Debugging
*.log
backend/logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime / Diagnostic data
pids
*.pid
*.seed
*.pid.lock

# ====================================================================
# React Frontend (Vite Specific)
# ====================================================================
# Vite production build outputs
frontend/dist/
frontend/out/

# Local Vite preview/dev caches
frontend/.vite/

# ====================================================================
# Security & Environment Variables (CRITICAL: Never commit these)
# ====================================================================
.env
.env.local
.env.*.local
backend/.env
backend/.env.local
backend/.env.*.local
frontend/.env
frontend/.env.local
frontend/.env.*.local

# ====================================================================
# Testing & Coverage
# ====================================================================
coverage/
frontend/coverage/
backend/coverage/
.nyc_output

# ====================================================================
# Miscellaneous Caches
# ====================================================================
.eslintcache
.stylelintcache
.prettiercache
